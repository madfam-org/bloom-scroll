# Bloom Scroll Environment Configuration
#
# SECURITY WARNING: This is a template file. DO NOT use these values in production!
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Generate secure secrets (see instructions below)
# 3. Fill in your actual credentials
# 4. Never commit .env file to version control

# ============================================
# Application
# ============================================

APP_NAME=Bloom Scroll
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=INFO

# ============================================
# Database Configuration (PostgreSQL + pgvector)
# ============================================

# Format: postgresql+asyncpg://username:password@host:port/database
# IMPORTANT: Change the password! Do not use default 'postgres:postgres'
DATABASE_URL=postgresql+asyncpg://bloom:CHANGE_THIS_PASSWORD@localhost:5432/bloom_scroll
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================
# Redis Configuration
# ============================================

# Primary cache and rate limiting (DB 0)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ============================================
# Celery Task Queue
# ============================================

# Uses separate Redis databases for broker and results
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# Milvus Vector Database
# ============================================

# Required for semantic similarity and serendipity algorithm
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=bloom_embeddings

# ============================================
# Authentication & Security
# ============================================

# Application Secret Key - REQUIRED (min 32 characters)
# Generate with: openssl rand -hex 32
# NEVER use the placeholder value!
SECRET_KEY=<generate-with-openssl-rand-hex-32>

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Janua SSO (Centralized Authentication)
JANUA_API_URL=http://localhost:8000/api/v1
# Generate with: openssl rand -hex 32
JANUA_JWT_SECRET=<generate-with-openssl-rand-hex-32>
JANUA_JWT_ALGORITHM=HS256
AUTH_ENABLED=true
# Production: https://auth.madfam.io/api/v1

# ============================================
# ML / Embedding Models
# ============================================

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
BIAS_MODEL=bucketresearch/politicalBiasBERT
EMBEDDING_DIMENSION=384

# ============================================
# Content Aggregation
# ============================================

# OpenAlex (scholarly data) - provide your email for polite pool access
OPENALEX_EMAIL=your-email@example.com

# Scraping schedule and limits
SCRAPE_INTERVAL_HOURS=6
MAX_CONCURRENT_SCRAPERS=5
REQUEST_TIMEOUT_SECONDS=30

# ============================================
# Feed Configuration
# ============================================

# The "Slow Web" - finite feed sizes
DEFAULT_FEED_SIZE=20
MINI_BLOOM_SIZE=5
SERENDIPITY_WEIGHT=0.7

# ============================================
# CORS Configuration
# ============================================

# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ============================================
# Server
# ============================================

PORT=3095

# ============================================
# Monitoring & Observability (Optional)
# ============================================

# Sentry Error Tracking
# SENTRY_DSN=https://<key>@<project>.ingest.sentry.io/<id>

# ============================================
# Docker Compose Overrides
# ============================================
#
# These are used by docker-compose.yml services.
# If running with Docker, the compose file sets these automatically.
#
# POSTGRES_USER=bloom
# POSTGRES_PASSWORD=bloom_dev
# POSTGRES_DB=bloom_dev
# WORKER_TYPE=aggregator

# ============================================
# Quick Start for Development
# ============================================
#
# To get started quickly:
#
# 1. Generate secure secrets:
#    SECRET_KEY=$(openssl rand -hex 32)
#    JANUA_JWT_SECRET=$(openssl rand -hex 32)
#
# 2. Start infrastructure with Docker Compose:
#    docker compose up -d postgres redis
#
# 3. Start the full stack:
#    docker compose up
#
# 4. Or run the backend directly:
#    cd backend && uvicorn app.main:app --reload --port 5200
#
# Port Allocation:
#   API:        5200
#   Frontend:   5201
#   PostgreSQL: 5432 (mapped to 5434 in dev compose)
#   Redis:      6379 (mapped to 6381 in dev compose)
#   Milvus:     19530
