# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bloom_scroll
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=bloom_embeddings

# Application Settings
APP_NAME=Bloom Scroll
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=INFO

# Security (Legacy)
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Janua SSO (Centralized Authentication)
JANUA_API_URL=https://auth.madfam.io/api/v1
JANUA_JWKS_URI=https://auth.madfam.io/.well-known/jwks.json
JANUA_JWT_ISSUER=https://auth.madfam.io
JANUA_JWT_AUDIENCE=
# Legacy development fallback only; production verifies RS256 via JWKS.
JANUA_JWT_SECRET=dev-shared-janua-secret-32chars
JANUA_JWT_ALGORITHM=RS256
JANUA_JWKS_CACHE_SECONDS=300
# Local dev tip: set AUTH_ENABLED=false so the quickstart ingest curls work
# without a Janua token. Production keeps this true; mutating endpoints
# (/api/v1/ingest/*, /api/v1/interactions/*) 401 without credentials.
AUTH_ENABLED=true

# Service key for machine callers of write endpoints (the ingestion CronJob
# sends it via X-API-Key). Empty disables the key path.
INGEST_API_KEY=

# API Keys for External Services
OPENALEX_EMAIL=your-email@example.com  # For polite pool access

# Selva LLM gateway (OpenAI-compatible /v1). Perspective scoring stays
# dormant until SELVA_BASE_URL is set.
SELVA_BASE_URL=
SELVA_API_KEY=
SELVA_SCORING_MODEL=selva-default

# Observability (dormant when unset)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Per-IP GET rate limit on /api/* (0 disables)
RATE_LIMIT_PER_MINUTE=120

# Scraping Configuration
SCRAPE_INTERVAL_HOURS=6
MAX_CONCURRENT_SCRAPERS=5
REQUEST_TIMEOUT_SECONDS=30

# Feed Generation
DEFAULT_FEED_SIZE=20
MINI_BLOOM_SIZE=5
SERENDIPITY_WEIGHT=0.7

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
BIAS_MODEL=bucketresearch/politicalBiasBERT
EMBEDDING_DIMENSION=384

# CORS allowlist read by app/main.py middleware (comma-separated origins).
# Defaults cover almanac.solar production + local dev when unset.
CORS_ALLOWED_ORIGINS=

PORT=3095
